generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 1. 用户表
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  nickname     String
  avatarUrl    String?
  grade        String?  // form3/form4/form5/form6
  targetLevel  Int?     // 目标DSE等级 1-5
  currentLevel Int?     // 当前预估DSE等级 1-5
  isVip        Boolean  @default(false)
  vipExpireAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 关系
  abilities       UserAbility?
  vocabulary      UserVocabulary[]
  answers         UserAnswer[]
  errorQuestions  UserErrorQuestion[]
  dailyRecords    DailyStudyRecord[]
  studySessions   StudySession[]
  pkGamesAsUser1  VocabularyPkGame[] @relation("pk_games_user1")
  pkGamesAsUser2  VocabularyPkGame[] @relation("pk_games_user2")
  audioRecords    AudioRecord[]
}

// 2. 能力等级表
model UserAbility {
  id              String   @id @default(uuid())
  userId          String   @unique
  readingLevel    Int      @default(1)  // 阅读等级 1-5
  listeningLevel  Int      @default(1)  // 听力等级 1-5
  writingLevel    Int      @default(1)  // 写作等级 1-5
  speakingLevel   Int      @default(1)  // 口语等级 1-5
  vocabularyLevel Int      @default(1)  // 词汇等级 1-5
  grammarLevel    Int      @default(1)  // 语法等级 1-5
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// 3. 词汇表
model Vocabulary {
  id         String   @id @default(uuid())
  word       String
  phonetic   String?
  definition String
  frequency  Int?     // DSE考频
  topic      String?  // 主题分类
  example    String?  // 真题例句
  difficulty Int      @default(1)  // 难度 1-5
  createdAt  DateTime @default(now())

  userVocabulary UserVocabulary[]
}

// 4. 用户单词记忆表
model UserVocabulary {
  id               String   @id @default(uuid())
  userId           String
  vocabularyId     String
  status           String   @default("unknown")  // learned/unknown/learning
  lastReviewed     DateTime?
  nextReview       DateTime?  // 间隔重复
  difficultyFactor Float    @default(2.5)  // SR算法难度因子
  createdAt        DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id])

  @@unique([userId, vocabularyId])
}

// 5. 题库表
model Question {
  id          String   @id @default(uuid())
  type        String   // vocabulary/grammar/reading/listening/writing/speaking
  subType     String?  // 子题型
  topic       String?  // 知识点/主题
  difficulty  Int      @default(1)  // 难度 1-5
  content     String   // 题目内容
  options     String?  // 选项（JSON字符串）
  answer      String?  // 参考答案
  explanation String?  // 解析
  source      String?  // 来源：dse-20xx/ai-generated
  year        Int?     // DSE年份（如果是真题）
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  answers        UserAnswer[]
  errorQuestions UserErrorQuestion[]
  audioRecords   AudioRecord[]
}

// 6. 用户答题记录表
model UserAnswer {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  userAnswer String?  // 用户答案（JSON字符串）
  isCorrect  Boolean?
  score      Int?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])
}

// 7. 错题本表
model UserErrorQuestion {
  id           String   @id @default(uuid())
  userId       String
  questionId   String
  errorCount   Int      @default(1)
  lastWrongAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
}

// 8. 每日学习记录表
model DailyStudyRecord {
  id             String   @id @default(uuid())
  userId         String
  studyDate      DateTime @unique
  totalMinutes   Int      @default(0)
  totalScore     Int      @default(0)
  vocabularyScore Int?
  grammarScore   Int?
  readingScore   Int?
  listeningScore Int?
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// 9. 学习会话表
model StudySession {
  id            String   @id @default(uuid())
  userId        String
  currentModule Int      @default(0)
  modules       String?  // 预生成的模块列表题目（JSON字符串）
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// 10. 词汇PK对战表
model VocabularyPkGame {
  id         String   @id @default(uuid())
  user1Id    String
  user2Id    String?
  score1     Int      @default(0)
  score2     Int      @default(0)
  status     String   @default("waiting")  // waiting/playing/finished
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime @default(now())

  user1 User @relation("pk_games_user1", fields: [user1Id], references: [id])
  user2 User? @relation("pk_games_user2", fields: [user2Id], references: [id])
}

// 11. 语音记录表
model AudioRecord {
  id               String   @id @default(uuid())
  userId           String
  questionId       String?
  audioUrl         String?
  duration         Int?  // 时长（秒）
  asrText          String?
  pronunciationScore Float?
  contentScore     Float?
  createdAt        DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  question Question? @relation(fields: [questionId], references: [id])
}
