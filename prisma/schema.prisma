generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                      String              @id @default(uuid())
  email                   String              @unique
  password                String
  nickname                String
  avatarUrl               String?
  grade                   String?
  targetLevel             Int?
  currentLevel            Int?
  isVip                   Boolean             @default(false)
  vipExpireAt             DateTime?
  phone                   String?
  parentId                String?
  studyMode               String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  emailVerified           DateTime?
  resetToken              String?
  resetTokenExpiry        DateTime?
  verificationToken       String?
  verificationTokenExpiry DateTime?
  dailyRecords            DailyStudyRecord[]
  abilities               UserAbility?
  answers                 UserAnswer[]
  errorQuestions          UserErrorQuestion[]
  vocabulary              UserVocabulary[]
}

model UserAbility {
  id              String   @id @default(uuid())
  userId          String   @unique
  readingLevel    Int      @default(1)
  listeningLevel  Int      @default(1)
  writingLevel    Int      @default(1)
  speakingLevel   Int      @default(1)
  vocabularyLevel Int      @default(1)
  grammarLevel    Int      @default(1)
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model Vocabulary {
  id             String           @id @default(uuid())
  word           String
  phonetic       String?
  definition     String
  part           String?
  frequency      Int?
  topic          String?
  example        String?
  difficulty     Int              @default(1)
  createdAt      DateTime         @default(now())
  userVocabulary UserVocabulary[]
}

model UserVocabulary {
  id               String     @id @default(uuid())
  userId           String
  vocabularyId     String
  status           String     @default("unknown")
  lastReviewed     DateTime?
  nextReview       DateTime?
  difficultyFactor Float      @default(2.5)
  createdAt        DateTime   @default(now())
  vocabulary       Vocabulary @relation(fields: [vocabularyId], references: [id])
  user             User       @relation(fields: [userId], references: [id])

  @@unique([userId, vocabularyId])
}

model Question {
  id             String              @id @default(uuid())
  type           String
  subType        String?
  part           String?
  topic          String?
  difficulty     Int                 @default(1)
  content        String
  options        String?
  answer         String?
  explanation    String?
  source         String?
  year           Int?
  isApproved     Boolean             @default(false)
  createdAt      DateTime            @default(now())
  answers        UserAnswer[]
  errorQuestions UserErrorQuestion[]
}

model UserAnswer {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  userAnswer String?
  isCorrect  Boolean?
  score      Int?
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model UserErrorQuestion {
  id          String        @id @default(uuid())
  userId      String
  questionId  String
  errorCount  Int           @default(1)
  stage       Int           @default(1)
  nextReview  DateTime
  lastReview  DateTime?
  isMastered  Boolean       @default(false)
  lastWrongAt DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  reviews     ErrorReview[]
  question    Question      @relation(fields: [questionId], references: [id])
  user        User          @relation(fields: [userId], references: [id])

  @@unique([userId, questionId])
  @@index([userId, nextReview])
}

model ErrorReview {
  id            String            @id @default(uuid())
  errorId       String
  stageAtReview Int
  isCorrect     Boolean
  reviewedAt    DateTime          @default(now())
  error         UserErrorQuestion @relation(fields: [errorId], references: [id])

  @@index([errorId])
}

model DailyStudyRecord {
  id              String   @id @default(uuid())
  userId          String
  studyDate       DateTime @unique
  studyMode       String?
  totalMinutes    Int      @default(0)
  totalScore      Float    @default(0)
  accuracy        Float?
  nextDifficulty  Float?
  modulesData     String?
  recommendations String?
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId, studyDate])
}

model StudySession {
  id            String    @id @default(uuid())
  userId        String?
  currentModule Int       @default(0)
  modules       String?
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())
}

model PlacementSession {
  id                   String   @id @default(uuid())
  userId               String?
  grade                String
  questions            String
  answers              String
  currentQuestionIndex Int      @default(0)
  createdAt            DateTime @default(now())
}
